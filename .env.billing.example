# =====================================================
# BILLING SYSTEM CONFIGURATION
# =====================================================
# Copy these variables to your .env file

# PayPal Configuration
# Get credentials from https://developer.paypal.com
PAYPAL_MODE=sandbox                           # 'sandbox' for testing, 'live' for production
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_webhook_id_here       # Created in PayPal Developer Dashboard

# Email Configuration (Resend)
# Get API key from https://resend.com
RESEND_API_KEY=your_resend_api_key_here
BILLING_EMAIL_FROM=billing@dids.amdy.io

# Application URLs
FRONTEND_URL=https://dids.amdy.io
API_URL=https://dids.amdy.io

# Billing Settings
BILLING_GRACE_PERIOD_DAYS=7                   # Days before account suspension after payment failure
BILLING_RETRY_ATTEMPTS=3                       # Number of payment retry attempts
BILLING_INVOICE_DUE_DAYS=7                     # Days until invoice is due

# =====================================================
# SETUP INSTRUCTIONS
# =====================================================

# 1. PAYPAL SETUP (SANDBOX FOR TESTING)
#    - Go to https://developer.paypal.com
#    - Create a sandbox business account
#    - Get REST API credentials (Client ID & Secret)
#    - Create webhook for billing events
#
# 2. RESEND SETUP (EMAIL NOTIFICATIONS)
#    - Go to https://resend.com
#    - Sign up and verify your domain
#    - Generate API key
#
# 3. TEST CARDS (SANDBOX ONLY)
#    Visa:        4111111111111111
#    Mastercard:  5555555555554444
#    Amex:        378282246310005
#    Discover:    6011111111111117
#    Expiry:      Any future date (e.g., 12/2028)
#    CVV:         Any 3-4 digits (e.g., 123)
#
# 4. PRODUCTION DEPLOYMENT
#    - Switch PAYPAL_MODE to 'live'
#    - Use production PayPal credentials
#    - Verify webhook URLs in PayPal dashboard
#    - Test payment flow thoroughly before going live

# =====================================================
# WEBHOOK CONFIGURATION
# =====================================================
# Configure these webhook events in PayPal Dashboard:
#   - BILLING.SUBSCRIPTION.ACTIVATED
#   - BILLING.SUBSCRIPTION.CANCELLED
#   - PAYMENT.SALE.COMPLETED
#   - PAYMENT.SALE.DENIED
#   - PAYMENT.SALE.REFUNDED
#
# Webhook URL: https://dids.amdy.io/api/v1/billing/webhook/paypal
